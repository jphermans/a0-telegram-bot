# ============================================
# Telegram Bot Configuration
# ============================================

# Your Telegram bot token from @BotFather
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated)
# 1. Open Telegram and search for @userinfobot
# 2. It will reply with your numeric user ID
# 3. Add user IDs here, separated by commas
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ============================================
# ZeroClaw (A0) Configuration
# ============================================

# ZeroClaw API endpoint
# - For Docker (same network): http://zeroclaw:42617
# - For local development: http://localhost:42617
# - For remote server: http://your-server-ip:42617
A0_ENDPOINT=http://zeroclaw:42617

# ZeroClaw API key (optional)
# Leave empty if ZeroClaw doesn't require authentication
# If ZeroClaw is configured with API_KEY, put it here
A0_API_KEY=

# Request timeout in seconds (default: 300)
A0_TIMEOUT=300

# ============================================
# Optional Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
