# ============================================
# Telegram Bot Configuration
# ============================================

# Your Telegram bot token from @BotFather
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated)
# 1. Open Telegram and search for @userinfobot
# 2. It will reply with your numeric user ID
# 3. Add user IDs here, separated by commas
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ============================================
# A0 (Agent Zero) Configuration
# ============================================

# A0 API endpoint
# Format: http://<service_name>:<port>
# - For Docker (same network): http://agent-zero:80
# - For local development: http://localhost:80
# - Check your A0 docker-compose.yml for the service name and port
A0_ENDPOINT=http://agent-zero:80

# A0 API Key (REQUIRED)
# Where to find it:
# 1. Open your A0 Web UI in browser (e.g., http://localhost:42617)
# 2. Go to Settings (gear icon)
# 3. Look for "API Keys" section
# 4. Copy the API key shown there
# Note: This is different from your LLM provider API key
A0_API_KEY=your_a0_api_key_here

# Request timeout in seconds (default: 300)
A0_TIMEOUT=300

# ============================================
# Optional Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
