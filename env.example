# ============================================
# Telegram Bot Configuration
# ============================================

# Your Telegram bot token from @BotFather
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-123456
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram user IDs (comma-separated for multiple users)
# 1. Open Telegram and search for @userinfobot
# 2. It will reply with your numeric user ID
# 3. Add user IDs here, separated by commas
# Example: 123456789,987654321
TELEGRAM_ALLOWED_USERS=your_telegram_user_id_here

# ============================================
# A0 (Agent Zero) Configuration
# ============================================

# A0 API endpoint
# Format: http://<docker-service-name>:<internal-port>
# - For Docker Compose: http://agent-zero:80 (use the service name from your docker-compose.yml)
# - For local development: http://localhost:5030 (use the host port you mapped)
# Note: Inside Docker, use the service name, NOT localhost!
A0_ENDPOINT=http://agent-zero:80

# A0 API Key (REQUIRED)
# Where to find it:
# 1. Open your A0 Web UI in browser (e.g., http://localhost:5030)
# 2. Login with your credentials
# 3. Go to Settings (gear icon)
# 4. Look for "API Keys" section
# 5. Copy the API key shown there
# Example: a1b2c3d4-e5f6-7890-abcd-ef1234567890
# Note: This is different from your LLM provider API key!
A0_API_KEY=your_a0_api_key_here

# Request timeout in seconds (default: 300)
# Increase this if you have long-running agent responses
A0_TIMEOUT=300

# ============================================
# Optional Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
