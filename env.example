# Telegram Bot Configuration for Agent Zero
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated)
# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ===========================================
# A0 API CONFIGURATION
# ===========================================

# A0 API endpoint (use service name for Docker networking)
A0_ENDPOINT=http://agent-zero:8000

# A0 API key (if authentication is enabled on A0)
A0_API_KEY=

# Request timeout in seconds (default: 120)
A0_TIMEOUT=120

# ===========================================
# TELEGRAM POLLING CONFIGURATION
# ===========================================

# Long polling timeout in seconds (default: 30)
TELEGRAM_POLL_TIMEOUT=30

# Polling interval in seconds (default: 1.0)
TELEGRAM_POLL_INTERVAL=1.0

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Use JSON structured logging (recommended for Docker/production)
JSON_LOGS=false

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable file attachments (default: true)
ENABLE_ATTACHMENTS=true

# Maximum attachment size in bytes (default: 20MB)
MAX_ATTACHMENT_SIZE=20971520

# ===========================================
# RETRY CONFIGURATION
# ===========================================

# Maximum retry attempts on failure (default: 5)
MAX_RETRIES=5

# Delay between retries in seconds (default: 5.0)
RETRY_DELAY=5.0
