# ============================================
# Telegram Bot Configuration
# ============================================

# Your Telegram bot token from @BotFather
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated)
# 1. Open Telegram and search for @userinfobot
# 2. It will reply with your numeric user ID
# 3. Add user IDs here, separated by commas
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ============================================
# A0 (Agent Zero) Configuration
# ============================================

# A0 API endpoint
# - For Docker (same network): http://a0:8000
# - For local development: http://localhost:8000
# - For remote server: http://your-server-ip:8000
# Note: Use the service name from your docker-compose.yml
A0_ENDPOINT=http://a0:8000

# A0 API key (optional)
# Leave empty if A0 doesn't require authentication
# If A0 is configured with API authentication, put the key here
A0_API_KEY=

# Request timeout in seconds (default: 300)
A0_TIMEOUT=300

# ============================================
# Optional Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
