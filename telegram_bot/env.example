# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789,987654321

# A0 Configuration
A0_ENDPOINT=http://agent-zero:80
A0_API_KEY=your_a0_api_key_here
A0_TIMEOUT=300

# Project Configuration (optional)
# Comma-separated list of available project names
TELEGRAM_PROJECTS=my-project,another-project
# Default project to use if none selected (optional)
TELEGRAM_DEFAULT_PROJECT=my-project

# Shared Volume Configuration
SHARED_VOLUME_PATH=/shared

# Logging
LOG_LEVEL=INFO
